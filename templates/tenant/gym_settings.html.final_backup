{% extends 'tenant/base.html' %}{% block title %}Gym Settings{% endblock %}{% block body %}<div class="page-header"><div><h1 class="page-title">Gym Settings</h1><p class="page-desc">Configure default fee and subscription rules</p></div></div><div class="settings-card"><div class="card-header"><h3>Fee & Subscription</h3></div><form method="post" class="settings-form">{% csrf_token %}<div class="form-field"><label>Default Monthly Fee (₹)</label>{{ form.default_monthly_fee }}</div><div class="form-field"><label>Subscription Generation Day</label>{{ form.subscription_generation_day }}<small>Day of month when subscriptions are auto-generated</small></div><div class="form-field"><label>Due Date Offset (days after generation)</label>{{ form.due_date_offset }}</div><div class="form-field"><label>Late Fee Penalty (%)</label>{{ form.late_fee_penalty }}</div><div class="form-actions"><button type="submit" class="btn-primary">Save Settings</button></div></form></div>{% endblock %}